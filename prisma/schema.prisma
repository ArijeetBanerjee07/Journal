generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  ambience  String
  text      String
  emotion   String?
  keywords  String?
  summary   String?
  createdAt DateTime @default(now())
}
